{
	"name": "acme-website",
	"version": "1.7.0",
	"private": true,
	"description": "A blank template to get started with Payload 3.0",
	"license": "MIT",
	"author": {
		"name": "Oliver",
		"url": "https://oliverpan.vercel.app"
	},
	"scripts": {
		"build": "next build",
		"dev": "dotenv -e .env -- bun run dev:services && next dev --turbopack",
		"dev:next": "next dev --turbopack",
		"dev:services": "docker compose up -d",
		"devsafe": "rm -rf .next && next dev",
		"generate:importmap": "payload generate:importmap",
		"generate:types": "payload generate:types",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt --check",
		"format:fix": "oxfmt",
		"check": "oxfmt --check && oxlint",
		"check:fix": "oxfmt && oxlint --fix",
		"typecheck": "tsc --noEmit",
		"payload": "payload",
		"start": "next start",
		"services:start": "docker compose up -d",
		"services:stop": "docker compose down",
		"services:logs": "docker compose logs -f",
		"services:reset": "docker compose down -v && docker compose up -d",
		"services:status": "docker compose ps",
		"email:start": "docker compose up -d inbucket",
		"email:stop": "docker compose stop inbucket",
		"email:logs": "docker compose logs -f inbucket",
		"email:test": "bun run src/scripts/test-email.ts",
		"s3:start": "docker compose up -d minio",
		"s3:stop": "docker compose stop minio",
		"s3:logs": "docker compose logs -f minio",
		"s3:console": "open http://localhost:9002",
		"db:start": "docker compose up -d postgres",
		"db:stop": "docker compose stop postgres",
		"db:logs": "docker compose logs -f postgres",
		"db:reset": "docker compose down -v postgres && docker compose up -d postgres",
		"db:connect": "docker exec -it acme-postgres psql -U postgres -d acme-website",
		"test": "dotenv -e .env -- bun run src/tests/helper/run.ts",
		"test:run": "dotenv -e .env -- bun run src/tests/helper/run.ts",
		"test:run:single": "dotenv -e .env -- bun run src/tests/helper/run.ts --",
		"test:db:create": "docker exec acme-postgres psql -U postgres -tc \"SELECT 1 FROM pg_database WHERE datname='acme-website_test'\" | grep -q 1 || docker exec acme-postgres psql -U postgres -c 'CREATE DATABASE \"acme-website_test\";'"
	},
	"dependencies": {
		"@base-ui/react": "^1.5.0",
		"@better-auth/passkey": "1.6.18",
		"@daveyplate/better-auth-ui": "^3.4.0",
		"@payloadcms/db-postgres": "^3.85.1",
		"@payloadcms/email-nodemailer": "^3.85.1",
		"@payloadcms/email-resend": "^3.85.1",
		"@payloadcms/live-preview-react": "^3.85.1",
		"@payloadcms/next": "^3.85.1",
		"@payloadcms/plugin-import-export": "^3.85.1",
		"@payloadcms/plugin-seo": "^3.85.1",
		"@payloadcms/richtext-lexical": "^3.85.1",
		"@payloadcms/storage-s3": "^3.85.1",
		"@payloadcms/ui": "^3.85.1",
		"@react-email/components": "^1.0.12",
		"@react-email/render": "^2.0.8",
		"@tanstack/react-form": "^1.33.0",
		"@vercel/analytics": "^2.0.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"better-auth": "1.6.18",
		"better-auth-harmony": "^1.3.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.4.0",
		"geist": "^1.7.2",
		"graphql": "^16.14.2",
		"lucide-react": "^0.577.0",
		"motion": "^12.40.0",
		"next": "^16.2.9",
		"next-themes": "^0.4.6",
		"nuqs": "^2.8.9",
		"payload": "^3.85.1",
		"payload-auth": "^1.9.4",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"react-medium-image-zoom": "^5.4.7",
		"resend": "^6.12.4",
		"sharp": "0.34.5",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"vaul": "^1.1.2"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.3.1",
		"@tailwindcss/typography": "^0.5.20",
		"@types/bun": "1.3.14",
		"@types/node": "^22.19.19",
		"@types/react": "19.2.15",
		"@types/react-dom": "19.2.3",
		"dotenv-cli": "^11.0.0",
		"oxfmt": "^0.54.0",
		"oxlint": "^1.69.0",
		"postcss": "^8.5.15",
		"tailwindcss": "^4.3.1",
		"tsx": "^4.22.4",
		"tw-animate-css": "^1.4.0",
		"typescript": "6.0.3",
		"zod": "^4.4.3"
	},
	"engines": {
		"node": ">=22"
	}
}
